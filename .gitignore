# Grok Build - consolidated repo for harness, settings, agents, skills, hooks, rules and configuration history.
# One repo for all Grok global changes over time (no proliferation of repos).

# === Transient / runtime / large data (do not version) ===
.grok/sessions/
.grok/usage-data/
.grok/active_sessions*
.grok/active_sessions.lock
.grok/tmp/
.grok/downloads/
.grok/logs/
.grok/upload_queue/
.grok/.last-*
**/.tmp/
**/*.log
**/*.bak

# === Caches and marketplace ===
.grok/marketplace-cache/
.grok/plugins/
.grok/cache/
.grok/models_cache.json
.grok/tip_cursor.json
.grok/slash-mru.json

# === Secrets and credentials (use PowerShell SecretStore) ===
**/*secret*
**/*.key
**/*.pem
**/.env
**/.credentials*
**/*token*
**/*password*

# === IDE / OS noise ===
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# === Projects ===
# Your Grok projects live here and can be versioned in this same grok-build repo.
# (We are grouping everything in one repo as requested - no flood of separate repos.)

# Ignore heavy generated / transient data inside projects
Projects/**/__pycache__/
Projects/**/.git/
Projects/**/sessions/
Projects/**/usage-data/
Projects/**/active_sessions*
Projects/**/*.log
Projects/**/*.bak
Projects/**/terminals/
Projects/**/raw/
Projects/**/build/
Projects/**/dist/

# Track the actual project work (code, docs, handoffs, project-local .grok/, AGENTS.md, etc.)
# You can still be selective when staging:
#   git add Projects/Jarvis2/jarvis2_app/ Projects/Jarvis2/handoffs/ Projects/Jarvis2/.grok/ ...
!Projects/

# === Large or refreshable libraries ===
# Library corpora can be large; track metadata + important files.
# Full refresh via scripts.
.grok/library/*/
!.grok/library/*/_meta.json
!.grok/library/*/*.md   # keep core docs if small

# === Other generated ===
.grok/CHANGELOG.json   # if regenerated

# Keep the harness core tracked (agents, skills, config, hooks, rules, etc.)
# These are explicitly added in commits.